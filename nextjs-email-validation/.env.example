# ── Requiems API ──────────────────────────────────────────────────────────────
# Get a free API key at https://requiems.xyz
# The root ../.env is symlinked as .env.local — you can also copy this file.
REQUIEMS_API=requiem_YOUR_KEY_HERE

# ── Better Auth ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your_secret_here_at_least_32_chars
BETTER_AUTH_URL=http://localhost:3000
